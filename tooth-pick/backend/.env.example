# Database Configuration
DATABASE_URL=postgresql://toothpick_user:toothpick_password@localhost:5432/toothpick_db
POSTGRES_USER=toothpick_user
POSTGRES_PASSWORD=toothpick_password
POSTGRES_DB=toothpick_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=ToothPick API
VERSION=1.0.0
DESCRIPTION=Plataforma dental profesional API
DEBUG=True

# CORS Settings
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001","https://toothpick.com"]
ALLOWED_METHODS=["GET","POST","PUT","DELETE","PATCH","OPTIONS"]
ALLOWED_HEADERS=["*"]

# Redis Configuration (for caching and sessions)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Email Configuration (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@toothpick.com
FROM_NAME=ToothPick Platform

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Payment Configuration (Stripe)
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=["jpg","jpeg","png","pdf","doc","docx"]

# Monitoring & Logging
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=INFO
ENABLE_METRICS=True

# External APIs
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Mobile App
MOBILE_APP_PACKAGE=com.toothpick.mobile
MOBILE_DEEP_LINK_SCHEME=toothpick

# Production Settings
ENVIRONMENT=development
WORKERS=4
HOST=0.0.0.0
PORT=8000

# Healthcare Compliance
HIPAA_COMPLIANT=True
DATA_ENCRYPTION=True
AUDIT_LOGGING=True
